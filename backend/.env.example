# Database Configuration
DATABASE_URL=postgresql://user:password@localhost/chatbi

# Redis Configuration
REDIS_URL=redis://localhost:6379

# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DEFAULT_LLM_PROVIDER=openai

# Cube.js Configuration
CUBE_API_URL=http://localhost:4000
CUBE_API_SECRET=your_cube_api_secret_here

# Security Configuration
SECRET_KEY=your_secret_key_here_minimum_32_characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8501","http://localhost:8080"]

# Application Configuration
PROJECT_NAME=Chat BI Backend
VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true